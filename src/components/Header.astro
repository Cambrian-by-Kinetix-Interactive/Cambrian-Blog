---
import { BLOG_CATEGORIES } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<span class="logo-text">Cambrian</span>
			<span class="logo-sub">powered by Cavexia AI™</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			{BLOG_CATEGORIES.map((cat) => (
				<HeaderLink href={`/blog/category/${cat.slug}/`}>{cat.name}</HeaderLink>
			))}
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="nav-right">
			<a href="https://cambrianmusic.com" class="nav-cta" target="_blank" rel="noopener noreferrer">
				Visit Cambrian
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(10, 10, 10, 0.9);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
	}
	nav {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5em;
		height: 60px;
	}
	.logo-link {
		text-decoration: none;
		color: var(--text-primary);
	}
	.logo-link:hover {
		color: var(--text-primary);
	}
	.logo-text {
		font-weight: 600;
		font-size: 1.125rem;
		letter-spacing: -0.01em;
	}
	.logo-sub {
		display: block;
		font-size: 0.625rem;
		font-weight: 400;
		color: var(--text-muted);
		letter-spacing: 0.02em;
		line-height: 1;
		margin-top: -0.1em;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.nav-right {
		display: flex;
		align-items: center;
	}
	.nav-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.4em 1em;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--accent);
		border: 1px solid var(--accent);
		border-radius: 20px;
		transition: all var(--transition);
	}
	.nav-cta:hover {
		background: var(--accent);
		color: var(--bg-primary);
	}
	@media (max-width: 720px) {
		nav {
			padding: 0 1em;
		}
		.nav-cta {
			font-size: 0.75rem;
			padding: 0.35em 0.75em;
		}
	}
</style>
