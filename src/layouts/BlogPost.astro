---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategoryByName } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, category, pubDate, updatedDate, heroImage } = Astro.props;
const categorySlug = getCategoryByName(category)?.slug;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"author": {
				"@type": "Person",
				"name": "Logan"
			},
			"publisher": {
				"@type": "Organization",
				"name": "Cavexia AI"
			},
			"datePublished": pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString(),
			"dateModified": updatedDate ? (updatedDate instanceof Date ? updatedDate.toISOString() : new Date(updatedDate).toISOString()) : (pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString()),
			...(heroImage ? { "image": heroImage.src } : {})
		})} />
		<style>
			main {
				width: var(--max-width-prose);
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2.5em 1em 4em;
			}
			.post-header {
				margin-bottom: 2.5em;
			}
			.post-meta {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.75em;
				margin-bottom: 1em;
			}
			.category-link {
				display: inline-flex;
				padding: 0.35rem 0.7rem;
				border: 1px solid var(--border-color);
				border-radius: 999px;
				background: var(--bg-card);
				color: var(--label-color);
				font-size: 0.75rem;
				font-weight: 600;
				letter-spacing: 0.08em;
				text-decoration: none;
				text-transform: uppercase;
			}
			.post-meta time {
				font-size: 0.8125rem;
				color: var(--text-muted);
			}
			.last-updated-on {
				font-size: 0.8125rem;
				color: var(--text-muted);
				font-style: italic;
			}
			.post-header h1 {
				font-size: 2.25em;
				margin: 0 0 0.5em;
				letter-spacing: -0.03em;
				line-height: 1.15;
			}
			.post-header .description {
				font-size: 1.1rem;
				color: var(--text-secondary);
				margin: 0;
				line-height: 1.6;
			}
			.author-byline {
				font-size: 0.875rem;
				color: var(--text-muted);
				margin: 0.75em 0 0;
			}
			.hero-image {
				margin: 0 0 2em;
			}
			.hero-image img {
				width: 100%;
				border-radius: var(--radius-lg);
				border: 1px solid var(--border-color);
			}
			.prose {
				color: var(--text-secondary);
				line-height: 1.8;
			}
			.email-signup {
				margin-top: 3em;
				padding: 1.5em;
				border: 1px solid var(--border-color);
				border-radius: var(--radius-lg);
				background: var(--bg-card);
			}
			.email-signup-heading {
				margin: 0 0 0.75em;
				font-size: 1rem;
				font-weight: 600;
				color: var(--text-primary);
			}
			.email-signup-form {
				display: flex;
				gap: 0.5em;
			}
			.email-signup-form input {
				flex: 1;
				padding: 0.6em 0.75em;
				border: 1px solid var(--border-color);
				border-radius: 8px;
				background: var(--bg-primary);
				color: var(--text-primary);
				font-size: 0.875rem;
			}
			.email-signup-form input::placeholder {
				color: var(--text-muted);
			}
			.email-signup-form button {
				padding: 0.6em 1.25em;
				border: none;
				border-radius: 8px;
				background: var(--accent);
				color: var(--bg-primary);
				font-weight: 600;
				font-size: 0.875rem;
				cursor: pointer;
				transition: background var(--transition);
			}
			.email-signup-form button:hover {
				background: var(--accent-hover);
			}
			.post-cta {
				margin-top: 1.5em;
				padding: 1.5em;
				border: 1px solid var(--border-color);
				border-radius: var(--radius-lg);
				background: linear-gradient(180deg, rgba(0, 255, 153, 0.05), rgba(0, 255, 153, 0.02));
			}
			.post-cta p {
				margin: 0;
				font-size: 1rem;
				color: var(--text-secondary);
			}
			.post-cta a {
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
			}
			.post-cta a:hover {
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				main {
					padding: 1.5em 1em 3em;
				}
				.post-header h1 {
					font-size: 1.75em;
				}
				.email-signup-form {
					flex-direction: column;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="post-header">
					<div class="post-meta">
						{categorySlug && <a class="category-link" href={`/blog/category/${categorySlug}/`}>{category}</a>}
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									(Updated <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					{description && <p class="description">{description}</p>}
					<p class="author-byline">By Logan, Founder of Cambrian</p>
				</div>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<slot />
				</div>

				<div class="email-signup">
					<p class="email-signup-heading">Get new posts delivered to your inbox.</p>
					<form class="email-signup-form" action="/api/subscribe" method="POST">
						<input type="email" name="email" placeholder="you@example.com" required />
						<button type="submit">Subscribe</button>
					</form>
				</div>

				<div class="post-cta">
					<p>
						Ready to start?
						<a href="https://cambrianmusic.com/login?register=true">List your first track on Cambrian →</a>
						{' '}or{' '}
						<a href="https://cambrianmusic.com/browse">Browse AI-licensed music →</a>
					</p>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
